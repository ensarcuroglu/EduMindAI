@{
    Layout = null; /* Ana layout'tan bağımsız, tam sayfa */
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - EduMind AI</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

    <div class="login-container">

        <div class="visual-side">
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
            <div class="orb orb-3"></div>

            <div class="visual-content glass-panel">
                <div class="brand">
                    <i class="fa-solid fa-brain"></i>
                    <span>EduMind.AI</span>
                </div>

                <div class="quote-slider">
                    <h1>Geleceğini Şekillendir.</h1>
                    <p>"Yapay zeka destekli kişisel asistanın ile potansiyelinin sınırlarını zorla."</p>

                    <div class="features-mini">
                        <div class="f-item"><i class="fa-solid fa-check"></i> Akıllı Planlama</div>
                        <div class="f-item"><i class="fa-solid fa-check"></i> Odak Analizi</div>
                        <div class="f-item"><i class="fa-solid fa-check"></i> 7/24 Mentor</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="form-side">
            <div class="form-wrapper fade-in">

                <div class="form-header">
                    <h2 id="formTitle">Tekrar Hoşgeldin! 👋</h2>
                    <p id="formSubtitle">Hesabına giriş yap ve çalışmaya başla.</p>
                </div>

                <div class="auth-tabs">
                    <button class="tab-btn active" data-target="login">Giriş Yap</button>
                    <button class="tab-btn" data-target="register">Kayıt Ol</button>
                </div>

                <form id="loginForm" class="auth-form active" onsubmit="return false;">

                    <div class="input-group">
                        <input type="email" id="loginEmail" required placeholder=" " autocomplete="off">
                        <label for="loginEmail">E-posta Adresi</label>
                        <i class="fa-regular fa-envelope input-icon"></i>
                    </div>

                    <div class="input-group">
                        <input type="password" id="loginPass" required placeholder=" " autocomplete="off">
                        <label for="loginPass">Şifre</label>
                        <i class="fa-solid fa-lock input-icon"></i>
                        <button type="button" class="toggle-pass" onclick="togglePassword('loginPass', this)">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>

                    <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" checked>
                            <span class="checkmark"></span>
                            Beni Hatırla
                        </label>
                        <a href="#" class="forgot-link">Şifremi Unuttum?</a>
                    </div>

                    <button class="btn-submit" onclick="handleLogin(this)">
                        <span>Giriş Yap</span>
                        <i class="fa-solid fa-arrow-right"></i>
                    </button>
                </form>

                <form id="registerForm" class="auth-form" onsubmit="return false;">

                    <div class="form-row">
                        <div class="input-group">
                            <input type="text" id="regName" required placeholder=" ">
                            <label for="regName">Ad</label>
                        </div>
                        <div class="input-group">
                            <input type="text" id="regSurname" required placeholder=" ">
                            <label for="regSurname">Soyad</label>
                        </div>
                    </div>

                    <div class="input-group">
                        <input type="email" id="regEmail" required placeholder=" ">
                        <label for="regEmail">E-posta Adresi</label>
                        <i class="fa-regular fa-envelope input-icon"></i>
                    </div>

                    <div class="input-group">
                        <input type="password" id="regPass" required placeholder=" ">
                        <label for="regPass">Şifre Oluştur</label>
                        <i class="fa-solid fa-lock input-icon"></i>
                    </div>

                    <div class="form-options">
                        <label class="checkbox-container">
                            <input type="checkbox" required>
                            <span class="checkmark"></span>
                            <a href="#" class="terms-link">Kullanım Şartlarını</a> kabul ediyorum.
                        </label>
                    </div>

                    <button class="btn-submit secondary" onclick="handleRegister(this)">
                        <span>Hesap Oluştur</span>
                        <i class="fa-solid fa-user-plus"></i>
                    </button>
                </form>

                <div class="social-login">
                    <span class="divider">veya şununla devam et</span>
                    <div class="social-btns">
                        <button class="s-btn google"><i class="fa-brands fa-google"></i> Google</button>
                        <button class="s-btn apple"><i class="fa-brands fa-apple"></i> Apple</button>
                    </div>
                </div>

            </div>
        </div>

    </div>

    <script src="~/js/login.js" asp-append-version="true"></script>
</body>
</html>