@{
    ViewData["Title"] = "Akademik Performans Analizi";
}

<!-- Gerekli Kütüphaneler -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
<link href="~/css/academic.css" rel="stylesheet" />

<div class="container-fluid dashboard-container">

    <!-- Üst Başlık -->
    <div class="row mb-4 animate-fade-in-down">
        <div class="col-12 text-center">
            <h1 class="display-5 fw-bold text-gradient">Akademik İzleme Merkezi</h1>
            <p class="text-muted">Yapay zeka destekli performans analizi ve gelecek tahmini.</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- SOL PANEL: Veri Girişi -->
        <div class="col-lg-4 col-md-12 animate-fade-in-left">

            <!-- Yeni Deneme Kartı -->
            <div class="card glass-card mb-4">
                <div class="card-header border-0 bg-transparent">
                    <h5 class="card-title mb-0"><i class="bi bi-plus-circle-fill text-primary me-2"></i>Yeni Deneme Ekle</h5>
                </div>
                <div class="card-body">
                    <form id="examForm">
                        <div class="row g-3 mb-3">
                            <div class="col-md-7">
                                <div class="form-floating">
                                    <input type="text" class="form-control glass-input" id="examName" placeholder="Deneme Adı">
                                    <label for="examName">Deneme Adı (Örn: TÖZOK-1)</label>
                                </div>
                            </div>
                            <div class="col-md-5">
                                <div class="form-floating">
                                    <input type="date" class="form-control glass-input" id="examDate">
                                    <label for="examDate">Tarih</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="text-secondary small fw-bold mb-0">DERS SONUÇLARI</h6>
                            <button type="button" class="btn btn-sm btn-light-soft rounded-pill" onclick="addLessonRow()">
                                <i class="bi bi-plus-lg"></i> Ders Ekle
                            </button>
                        </div>

                        <div id="lessonsContainer" class="lessons-scroll-area">
                            <!-- Dinamik Ders Satırları Buraya Gelecek -->
                        </div>

                        <div class="d-grid mt-4">
                            <button type="button" class="btn btn-primary-gradient shadow-sm" onclick="addExamToList()">
                                <i class="bi bi-save2 me-2"></i>Listeye Ekle
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Deneme Listesi Kartı -->
            <div class="card glass-card">
                <div class="card-header border-0 bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0"><i class="bi bi-list-check text-success me-2"></i>Analiz Listesi</h5>
                    <span id="examCountBadge" class="badge bg-primary rounded-pill">0</span>
                </div>
                <div class="card-body p-0">
                    <div id="examListArea" class="exam-list-container">
                        <div class="text-center text-muted py-5" id="emptyState">
                            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                            <small>Henüz deneme eklenmedi.</small>
                        </div>
                        <ul id="examList" class="list-group list-group-flush bg-transparent"></ul>
                    </div>
                </div>
                <div class="card-footer border-0 bg-transparent p-3">
                    <button type="button" class="btn btn-success-gradient w-100 py-2" onclick="sendToAnalysis()">
                        <i class="bi bi-cpu me-2"></i>Yapay Zeka ile Analiz Et
                    </button>
                </div>
            </div>
        </div>

        <!-- SAĞ PANEL: Sonuçlar ve Grafikler -->
        <div class="col-lg-8 col-md-12 animate-fade-in-right" id="resultPanel" style="display:none;">

            <!-- Özet İstatistik Kartları -->
            <div class="row g-3 mb-4" id="statsRow"></div>

            <!-- GRAFİK SATIRI 1: Ana Trend & Gelecek -->
            <div class="card glass-card mb-4">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-4"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Genel Trend ve Gelecek Tahmini</h5>
                    <div class="chart-container" style="position: relative; height:350px;">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- GRAFİK SATIRI 2: Radar & Risk Matrisi -->
            <div class="row g-4 mb-4">
                <!-- Radar Grafik -->
                <div class="col-md-6">
                    <div class="card glass-card h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-dark mb-3"><i class="bi bi-pentagon text-warning me-2"></i>Akademik Denge</h5>
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas id="radarChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Risk Matrisi (Scatter) -->
                <div class="col-md-6">
                    <div class="card glass-card h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-dark mb-3"><i class="bi bi-dice-5 text-danger me-2"></i>Risk Yönetimi Matrisi</h5>
                            <p class="small text-muted mb-2">Yanlış/Boş dengesine göre strateji analizi.</p>
                            <div class="chart-container" style="position: relative; height:280px;">
                                <canvas id="riskScatterChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- GRAFİK SATIRI 3: Ders Trendleri & Isı Haritası -->
            <div class="row g-4 mb-4">
                <!-- Ders Bazlı Çizgi Grafik -->
                <div class="col-md-12">
                    <div class="card glass-card">
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-dark mb-3"><i class="bi bi-bezier2 text-info me-2"></i>Ders Bazlı Gelişim Eğrileri</h5>
                            <div class="chart-container" style="position: relative; height:300px;">
                                <canvas id="lessonTrendChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Isı Haritası (HTML Tablo Olarak) -->
                <div class="col-md-12">
                    <div class="card glass-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h5 class="card-title fw-bold text-dark mb-0"><i class="bi bi-grid-3x3 text-success me-2"></i>Performans Isı Haritası</h5>
                                <div class="badge bg-light text-dark border">
                                    <span class="text-danger">● Düşük</span>
                                    <span class="text-warning mx-1">● Orta</span>
                                    <span class="text-success">● Yüksek</span>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-bordered text-center align-middle" id="heatmapTable">
                                    <!-- JS ile doldurulacak -->
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sözel Rapor -->
            <div class="card glass-card border-start border-4 border-primary">
                <div class="card-body">
                    <h5 class="card-title fw-bold text-dark mb-3"><i class="bi bi-robot me-2 text-primary"></i>AI Mentor Final Raporu</h5>
                    <div id="aiSummaryContent" class="ai-typing-effect text-muted small lh-lg"></div>
                </div>
            </div>

        </div>

    </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@2.1.0"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/academic.js"></script>